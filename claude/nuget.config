<?xml version="1.0" encoding="utf-8"?>
<!--
  Package sources for the Claude City API.

  The internal Demo.Cities (QA) and OpenMeteo.Api.Client (prod) packages are served
  from the local DevContext demo feeds; Formula.SimpleRepo / Dapper / test tooling
  come from nuget.org. These folder paths mirror the machine-global NuGet sources
  registered for this demo, declared here so the claude/ solution is self-describing.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="demo-qa" value="C:\.iJustHelp\dev-context-mcp-server\demo\data\nuget-repos\qa" />
    <add key="demo-prod" value="C:\.iJustHelp\dev-context-mcp-server\demo\data\nuget-repos\prod" />
  </packageSources>
</configuration>
